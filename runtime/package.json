{
  "name": "@cobolx/runtime",
  "version": "0.2.0",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json && node -e \"const s=require('path'),d='dist/runtime/src';require('fs').existsSync(d)&&require('fs').cpSync(d,'dist',{recursive:true})\"",
    "check": "tsc -p tsconfig.json --noEmit",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@cobolx/compiler": "0.2.0"
  }
}
